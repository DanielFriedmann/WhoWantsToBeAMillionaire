<Window x:Class="WhoWantsToBeAMillionaire.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wer wird Millionär?" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0d0d2b">

	<Window.Resources>
		<Style x:Key="AnswerButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#1a1a4e"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="Gold"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Padding" Value="10,15"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="border"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="5"
								Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
											  VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#2e2e7e"/>
								<Setter TargetName="border" Property="BorderBrush" Value="#FFD700"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" Background="#1a1a4e" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <TextBlock x:Name="QuestionText"
                           Text="Frage erscheint hier..."
                           Foreground="White" FontSize="18"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Border>

            
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

				<Button x:Name="AnswerA" Grid.Row="0" Grid.Column="0" Margin="5"
					 Content="A: Antwort" Click="Answer_Click" Tag="0"
					 Style="{StaticResource AnswerButtonStyle}"/>

				<Button x:Name="AnswerB" Grid.Row="0" Grid.Column="1" Margin="5"
						Content="B: Antwort" Click="Answer_Click" Tag="1"
						Style="{StaticResource AnswerButtonStyle}"/>

				<Button x:Name="AnswerC" Grid.Row="1" Grid.Column="0" Margin="5"
						Content="C: Antwort" Click="Answer_Click" Tag="2"
						Style="{StaticResource AnswerButtonStyle}"/>

				<Button x:Name="AnswerD" Grid.Row="1" Grid.Column="1" Margin="5"
						Content="D: Antwort" Click="Answer_Click" Tag="3"
						Style="{StaticResource AnswerButtonStyle}"/>
            </Grid>

            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="JokerFiftyFifty" Content="50:50"
                        FontSize="14" FontWeight="Bold"
                        Background="Gold" Foreground="#0d0d2b"
                        Padding="15,8" Margin="10,0"
                        Click="JokerFiftyFifty_Click"/>

                <Button x:Name="JokerSwap" Content="Frage tauschen"
                        FontSize="14" FontWeight="Bold"
                        Background="Gold" Foreground="#0d0d2b"
                        Padding="15,8" Margin="10,0"
                        Click="JokerSwap_Click"/>
            </StackPanel>
        </Grid>

		
		<Grid Grid.Column="1" Background="#111133">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="Gewinnleiter" Foreground="Gold"
					   FontWeight="Bold" FontSize="14"
					   HorizontalAlignment="Center" Margin="0,10,0,6"/>

			<ItemsControl Grid.Row="1" x:Name="PrizePanel"
						  VerticalAlignment="Top" Margin="8,0,8,8">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Margin="0,2" Padding="8,5" CornerRadius="5"
								BorderThickness="1.5">
							<Border.Style>
								<Style TargetType="Border">
									<Setter Property="Background" Value="#1a1a4e"/>
									<Setter Property="BorderBrush" Value="#333366"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsActive}" Value="True">
											<Setter Property="Background" Value="#B8860B"/>
											<Setter Property="BorderBrush" Value="Gold"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding IsReached}" Value="True">
											<Setter Property="Background" Value="#1a3a1a"/>
											<Setter Property="BorderBrush" Value="LimeGreen"/>
										</DataTrigger>
										<DataTrigger Binding="{Binding IsSafetyNet}" Value="True">
											<Setter Property="BorderBrush" Value="Orange"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="22"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="{Binding Level}"
										   Foreground="#aaaacc" FontSize="10"
										   VerticalAlignment="Center"/>
								<TextBlock Grid.Column="1"
										   Text="{Binding Amount, StringFormat='{}{0:N0} €'}"
										   Foreground="White" FontSize="12"
										   VerticalAlignment="Center">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Style.Triggers>
												<DataTrigger Binding="{Binding IsActive}" Value="True">
													<Setter Property="FontWeight" Value="Bold"/>
													<Setter Property="Foreground" Value="White"/>
												</DataTrigger>
												<DataTrigger Binding="{Binding IsReached}" Value="True">
													<Setter Property="Foreground" Value="LimeGreen"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</Grid>
    </Grid>
</Window>