<Window x:Class="WhoWantsToBeAMillionaire.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wer wird Millionär?" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#0d0d2b">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

        <TextBlock Text="Wer wird Millionär?"
                   FontSize="28" FontWeight="Bold"
                   Foreground="Gold" HorizontalAlignment="Center"
                   Margin="0,0,0,40"/>

        <TextBlock Text="Dein Name:" Foreground="White" 
                   FontSize="14" Margin="0,0,0,5"/>

        <TextBox x:Name="PlayerNameInput"
                 FontSize="14" Padding="8" Width="250"
                 Margin="0,0,0,20"/>

        <Button x:Name="StartButton" Content="SPIELEN"
                FontSize="16" FontWeight="Bold"
                Background="Gold" Foreground="#0d0d2b"
                Padding="20,10" Margin="0,0,0,10"
                Click="StartButton_Click"/>

        <Button x:Name="HighscoreButton" Content="HIGHSCORES"
                FontSize="16" FontWeight="Bold"
                Background="Transparent" Foreground="Gold"
                BorderBrush="Gold" BorderThickness="2"
                Padding="20,10"
                Click="HighscoreButton_Click"/>

    </StackPanel>
</Window>